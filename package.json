{
  "name": "@hopeio/utils",
  "version": "0.0.7",
  "description": "javascript utils",
  "type": "module",
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501",
  "exports": {
    "./package.json": "./package.json",
    "./types": {
      "types": "./src/types/index.d.ts",
      "import": "./src/types/index.d.ts",
      "default": "./src/types/index.d.ts"
    },
    "./*/*": {
      "types": "./src/*/*/index.ts",
      "import": "./src/*/*/index.ts",
      "default": "./src/*/*/index.ts"
    },
    "./*": {
      "types": "./src/*/index.ts",
      "import": "./src/*/index.ts",
      "default": "./src/*/index.ts"
    }
  },
  "typesVersions": {
    "*": {
      "types": ["src/types/index.d.ts"],
      "*/*": ["src/*/*/index.ts"],
      "*": ["src/*/index.ts"]
    }
  },
  "scripts": {
    "upgrade": "pnpm update --latest",
    "link": "pnpm link --global",
    "build": "vite build",
    "test": "vitest",
    "oxlint": "oxlint ./src",
    "fmt": "oxfmt ./src",
    "fmt:check": "oxfmt --check ./src",
    "pub": "npm publish --access public"
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopeio/diamond.git"
  },
  "keywords": [
    "diamond"
  ],
  "author": "liov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hopeio/diamond/issues"
  },
  "homepage": "https://github.com/hopeio/diamond#readme",
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.0",
    "dayjs": "^1.11.20",
    "localforage": "^1.10.0",
    "qs": "^6.15.1",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.30",
    "@types/node": "^25.6.0",
    "@types/qs": "^6.15.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.1.4"
  }
}
