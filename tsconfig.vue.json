{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "strict": false,
    "declaration": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/vue/**/*",
    "src/utils/types/**/*"
  ],
  "exclude": [
    "./node_modules",
    "./**/test.ts",
    "./**/test.js",
    "./**/*.test.js",
    "./**/*.test.ts"
  ]
}